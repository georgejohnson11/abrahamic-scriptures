{
  "name": "abrahamic-app",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "start": "npm run build:client && node server.js",
    "build:client": "vite build --config client/vite.config.js",
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "nodemon server.js",
    "dev:client": "vite --config client/vite.config.js"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "sqlite3": "^6.0.1"
  },
  "devDependencies": {
    "concurrently": "^8.2.1",
    "nodemon": "^3.0.1",
    "vite": "^5.0.0",
    "@vitejs/plugin-react": "^4.2.0"
  }
}
